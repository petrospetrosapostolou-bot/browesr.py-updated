tk.Button(tab10_2, text="Test", command=lambda: messagebox.showinfo("Driver Test", "Driver test simulated")).pack()

# ----------------- TAB 11: Updater -----------------
tab11 = ttk.Frame(tabs)
tabs.add(tab11, text="Updater")
status_update = tk.Label(tab11, text="")
status_update.pack(pady=10)

@safe_execute
def auto_update():
    BACKUP_FOLDER = os.path.join(SYSDIST, "BACKUPOFOLDPROGRAM")
    os.makedirs(BACKUP_FOLDER, exist_ok=True)
    
    # Backup current script
    current_script = os.path.realpath(__file__)
    backup_script = os.path.join(BACKUP_FOLDER, f"backup_{int(time.time())}.py")
    shutil.copy2(current_script, backup_script)
    
    # Create updater.py
    updater_code = f'''
import os, requests, shutil
SYSDIST = r"{SYSDIST}"
url = "https://raw.githubusercontent.com/petrospetrosapostolou-bot/browesr.py-updated/main/browesr.py"
dest = os.path.join(SYSDIST, "browesr.py")
try:
    r = requests.get(url, verify=False)
    with open(dest, "wb") as f:
        f.write(r.content)
    print("Updated successfully:", dest)
except Exception as e:
    print("Updater failed:", e)
'''
    updater_path = os.path.join(SYSDIST, "updater.py")
    with open(updater_path, "w") as f:
        f.write(updater_code)
    
    # Download latest main script automatically
    url_main = "https://raw.githubusercontent.com/petrospetrosapostolou-bot/browesr.py-updated/main/browesr.py"
    r = requests.get(url_main, verify=False)
    new_script_path = os.path.join(SYSDIST, "browesr.py")
    with open(new_script_path, "wb") as f:
        f.write(r.content)
    status_update.config(text=f"✅ Script updated!\nBackup: {backup_script}\nUpdater: {updater_path}")

tk.Button(tab11, text="Start Update", command=lambda: threading.Thread(target=auto_update).start()).pack(pady=10)

root.mainloop()
