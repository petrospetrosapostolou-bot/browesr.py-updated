# ----------------- TAB 10: Driver Lab -----------------
tab10 = ttk.Frame(tabs)
tabs.add(tab10, text="Driver Lab")
nested_tabs10 = ttk.Notebook(tab10)
nested_tabs10.pack(expand=1, fill="both")
tab10_1 = ttk.Frame(nested_tabs10)
